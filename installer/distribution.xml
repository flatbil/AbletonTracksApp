        <line choice="com.nuthouse.stagepad-bridge"/>
    </choices-outline>
    <choice id="com.nuthouse.stagepad-bridge" title="StagePad Bridge">
        <pkg-ref id="com.nuthouse.stagepad-bridge"/>
    </choice>
    <pkg-ref id="com.nuthouse.stagepad-bridge"
             version="1.0"
             onConclusion="none">StagePadBridge_component.pkg</pkg-ref>
</installer-gui-script>
